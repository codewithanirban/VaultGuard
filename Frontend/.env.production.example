# ════════════════════════════════════════════════════════
#  VaultGuard Frontend — Production Environment Variables
# ════════════════════════════════════════════════════════
#
#  Copy this file to .env.production and fill in the real
#  deployed backend URL. Vite injects these at build time —
#  so you must rebuild after changing any value.
# ════════════════════════════════════════════════════════

# The full URL of the deployed backend API.
# Do NOT include a trailing slash.
VITE_API_URL=https://your-backend.onrender.com
