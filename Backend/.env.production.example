# ════════════════════════════════════════════════════════
#  VaultGuard Backend — Production Environment Variables
# ════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in real values.
#  NEVER commit a .env file to source control.
# ════════════════════════════════════════════════════════

# ──── Server ────────────────────────────────────────
# The port the Express server listens on.
# Most PaaS providers (Render, Railway) inject PORT automatically.
PORT=5000

# Must be "production" in deployed environments.
# Controls debug logging, error verbosity, etc.
NODE_ENV=production

# ──── MongoDB ───────────────────────────────────────
# Full connection string to MongoDB Atlas (or any MongoDB instance).
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=

# ──── JWT ───────────────────────────────────────────
# Secret used to sign and verify JSON Web Tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# How long each token remains valid (e.g. 7d, 24h, 30m).
JWT_EXPIRES_IN=7d

# ──── Encryption (AES-256-CBC) ──────────────────────
# 64-character hex string (32 bytes) used to encrypt stored passwords.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ If you change this after data has been stored, existing entries become unreadable.
ENCRYPTION_KEY=

# ──── Google OAuth 2.0 ──────────────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The full URL Google redirects back to after consent.
# Must match exactly what is registered in Google Cloud Console.
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback

# ──── CORS / Frontend ──────────────────────────────
# The deployed frontend URL. Used for CORS origin allowlist.
CLIENT_URL=https://your-app.vercel.app

# The frontend URL used for OAuth redirects (token handoff).
FRONTEND_URL=https://your-app.vercel.app
